<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VillaFlorenceAlbania</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VillaFlorenceAlbania.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <header>
        <nav id="mainNavbar" class="navbar navbar-expand-lg fixed-top navbar-dark">
            <div class="container-fluid px-4">

                <!-- Brand -->
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">
                    𝓥𝓲𝓵𝓵𝓪 𝓕𝓵𝓸𝓻𝓮𝓷𝓬𝓮
                </a>

                <!-- Toggle (mobile) -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Links -->
                <div class="collapse navbar-collapse justify-content-end" id="navbarContent">
                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Home</a>
                        </li>

                        <!-- Optional future links -->
                        <!--
                        <li class="nav-item">
                            <a class="nav-link" href="#about">About</a>
                        </li>
                        -->

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT (FULL WIDTH) -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="text-center text-white py-4" style="background:#111;">
        <p class="mb-0">© 2026 Villa Florence Albania</p>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Navbar scroll effect -->
    <script>
        window.addEventListener("scroll", function () {
            const navbar = document.getElementById("mainNavbar");

            if (window.scrollY > 50) {
                navbar.classList.add("scrolled");
            } else {
                navbar.classList.remove("scrolled");
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>