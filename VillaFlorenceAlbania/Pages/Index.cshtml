@page
@model IndexModel

<!-- HERO -->
<section class="hero d-flex align-items-center text-white text-center">
    <div class="container">
        <h1 class="display-4 fw-bold">Luxury Villa by Lake Tirana</h1>
        <p class="lead">All-Season Private Pool – Enclosed in Winter, Open in Summer</p>
        <a href="#about" class="btn btn-light btn-lg mt-3">Explore Villa</a>
    </div>
</section>

<style>
    .hero {
        height: 100vh;
        background: url('/img/_DSC5615.jpg') center/cover no-repeat;
        position: relative;
    }

        .hero::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
        }

        .hero .container {
            position: relative;
            z-index: 2;
        }

    .card {
        transition: 0.3s;
    }

        .card:hover {
            transform: scale(1.03);
        }
</style>

<!-- POOL -->
<section class="py-5 bg-light text-center">
    <div class="container">
        <h2 class="mb-4"><i class="bi bi-water"></i> All-Season Private Pool</h2>
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="p-4 shadow-sm bg-white rounded">
                    <h4><i class="bi bi-snow"></i> Winter</h4>
                    <p>Heated & enclosed pool for cold days.</p>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="p-4 shadow-sm bg-white rounded">
                    <h4><i class="bi bi-brightness-high"></i> Summer</h4>
                    <p>Open-air pool with stunning views.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ABOUT -->
<section id="about" class="py-5 text-center">
    <div class="container">
        <h2 class="mb-4">The Villa</h2>
        <p class="lead">
            Luxury villa by Lake Tirana with a private pool, perfect for relaxation and comfort.
        </p>
    </div>
</section>

<!-- FLOOR NAVIGATION -->
<section class="py-5 bg-light text-center">
    <div class="container">
        <h2 class="mb-4">Explore the Villa</h2>
        <div class="row g-4 justify-content-center">

            <!-- Ground -->
            <div class="col-md-4">
                <a href="/GroundFloor" class="text-decoration-none text-dark">
                    <div class="card shadow-sm">
                        <img src="/img/_DSC5664.jpg" class="card-img-top" style="height:250px;object-fit:cover;">
                        <div class="card-body"><h5>Ground Floor</h5></div>
                    </div>
                </a>
            </div>

            <!-- Second -->
            <div class="col-md-4">
                <a href="/SecondFloor" class="text-decoration-none text-dark">
                    <div class="card shadow-sm">
                        <img src="/img/_DSC5475.jpg" class="card-img-top" style="height:250px;object-fit:cover;">
                        <div class="card-body"><h5>Second Floor</h5></div>
                    </div>
                </a>
            </div>

            <!-- Third -->
            <div class="col-md-4">
                <a href="/ThirdFloor" class="text-decoration-none text-dark">
                    <div class="card shadow-sm">
                        <img src="/img/_DSC5476.jpg" class="card-img-top" style="height:250px;object-fit:cover;">
                        <div class="card-body"><h5>Third Floor</h5></div>
                    </div>
                </a>
            </div>

        </div>
    </div>
</section>
<div class="row justify-content-center">
    <div class="col-md-6 d-flex justify-content-center">
        <a href="GuestAccess" class="text-decoration-none text-dark w-100">
            <div class="card shadow-sm border-0">
                <img src="/img/_DSC5718.jpg" class="card-img-top" style="height: 300px; object-fit: cover;">
                <div class="card-body text-center">
                    <h5 class="card-title">Guest Access</h5>
                    <p class="card-text">
                        Explore all areas of the villa, inside and out.
                    </p>
                </div>
            </div>
        </a>
    </div>
</div>
</div>
<!-- INTERACTION WITH GUESTS -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-4">Interaction with Guests</h2>

        <div class="row g-4">
            <div class="col-md-6">
                <p>
                    We are readily available throughout your stay. You can contact us anytime via phone
                    or Airbnb messages for assistance, information, or extra services like laundry or cleaning.
                </p>
                <p class="fw-semibold">
                    Your comfort and convenience are our top priorities.
                </p>

                <a href="tel:+355674924319" class="btn btn-dark mt-3">
                    <i class="bi bi-telephone"></i> +355 67 492 4319
                </a>
            </div>

            <div class="col-md-6">
                <ul class="list-unstyled">
                    <li><i class="bi bi-geo-alt"></i> 15 min to Tirana Center</li>
                    <li><i class="bi bi-airplane"></i> 30 min to Airport</li>
                    <li><i class="bi bi-bus-front"></i> 4 min to Bus Station</li>
                    <li><i class="bi bi-hospital"></i> 20 min to Hospital</li>
                    <li><i class="bi bi-shop"></i> 6 min to Shopping Center</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- MAP -->
<section class="py-5 bg-light text-center">
    <div class="container">
        <h2 class="mb-4">Location</h2>

        <div class="ratio ratio-16x9 rounded shadow">
            <iframe src="https://maps.google.com/maps?q=Lake%20Tirana&t=&z=13&ie=UTF8&iwloc=&output=embed"
                    allowfullscreen>
            </iframe>
        </div>

        <a href="https://maps.app.goo.gl/3rHQ67RZrKzzHRT58" target="_blank"
           class="btn btn-outline-dark mt-3">
            Open in Google Maps
        </a>
    </div>
</section>
