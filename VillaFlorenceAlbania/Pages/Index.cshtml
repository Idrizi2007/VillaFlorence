@page
@model IndexModel

<!-- HERO SECTION -->
<section class="hero d-flex align-items-center text-white text-center">
    <div class="container">
        <h1 class="display-4 fw-bold">Luxury Villa by Lake Tirana</h1>
        <p class="lead">All-Season Private Pool – Enclosed in Winter, Open in Summer</p>
        <a href="#about" class="btn btn-light btn-lg mt-3">Explore Villa</a>
    </div>
</section>

<!-- HERO STYLE -->
<style>
    .hero {
        height: 100vh;
        background: url('/img/_DSC5615.jpg') center/cover no-repeat;
        position: relative;
    }

        .hero::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.4);
        }

        .hero .container {
            position: relative;
            z-index: 2;
        }
</style>

<!-- POOL HIGHLIGHTS -->
<section class="py-5 bg-light text-center">
    <div class="container">
        <h2 class="mb-4"><i class="bi bi-water"></i> All-Season Private Pool</h2>
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="p-4 shadow-sm bg-white rounded">
                    <h4><i class="bi bi-snow"></i> Winter (Oct–Apr)</h4>
                    <p>Heated & enclosed pool – perfect for relaxing even on cold or rainy days.</p>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="p-4 shadow-sm bg-white rounded">
                    <h4><i class="bi bi-brightness-high"></i> Summer (May–Sep)</h4>
                    <p>Open-air pool with stunning views – your perfect summer getaway.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="py-5 text-center">
    <div class="container">
        <h2 class="mb-4">Why You'll Love It</h2>
        <div class="row g-4">
            <div class="col-md-3">
                <i class="bi bi-water fs-1"></i>
                <p>Private pool all year</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-thermometer-half fs-1"></i>
                <p>Heated & enclosed in winter</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-tree fs-1"></i>
                <p>Open-air summer setup</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-shield-lock fs-1"></i>
                <p>Total privacy & relaxation</p>
            </div>
        </div>
    </div>
</section>

<!-- ABOUT -->
<section id="about" class="py-5 bg-light">
    <div class="container">
        <h2 class="mb-4 text-center">My Property</h2>
        <p class="lead text-center">
            Indulge in luxury at our stunning villa, nestled by the shores of Lake Tirana.
            Enjoy your own private pool all year round.
        </p>
        <p>
            During the colder months, the pool is fully enclosed and sheltered, perfect for relaxing swims
            even on chilly or rainy days.
        </p>
        <p>
            In summer, the structure is completely removable, transforming the space into an open-air oasis
            filled with sunlight and nature.
        </p>
        <p class="text-center fw-semibold">
            Ideal for romantic getaways, family weekends, or peaceful stays with friends.
        </p>
    </div>
</section>

<!-- INTERIOR HIGHLIGHTS -->
<section id="interior" class="py-5 text-center">
    <div class="container">
        <h2 class="mb-4">Interior Highlights</h2>
        <p class="lead mb-5">
            Experience sophistication and comfort in every detail of this luxury villa.
        </p>

        <div class="row align-items-center g-4">
            <div class="col-md-6 text-start">
                <ul class="list-unstyled fs-5">
                    <li><i class="bi bi-house-door-fill me-2"></i> 6 spacious bedrooms & 7 modern bathrooms</li>
                    <li><i class="bi bi-cup-straw me-2"></i> 2 large living rooms with premium furnishings</li>
                    <li><i class="bi bi-bounding-box-circles me-2"></i> Open-plan first floor with minibar & dining area</li>
                    <li><i class="bi bi-eye-fill me-2"></i> Panoramic views of pool, jacuzzi, and landscaped garden</li>
                </ul>
            </div>

            <div class="col-md-6">
                <div id="interiorCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-indicators">
                        <button type="button" data-bs-target="#interiorCarousel" data-bs-slide-to="0" class="active"></button>
                        <button type="button" data-bs-target="#interiorCarousel" data-bs-slide-to="1"></button>
                    </div>

                    <div class="carousel-inner rounded shadow-sm" style="height: 75vh;">
                        <div class="carousel-item active">
                            <img src="~/img/_DSC5620.jpg" class="d-block w-100 h-100" style="object-fit: cover;">
                        </div>
                        <div class="carousel-item">
                            <img src="~/img/_DSC5618.jpg" class="d-block w-100 h-100" style="object-fit: cover;">
                        </div>
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#interiorCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#interiorCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FLOOR NAVIGATION -->
<section class="py-5 bg-light text-center">
    <div class="container">
        <h2 class="mb-4">Explore the Villa</h2>

        <div class="row justify-content-center">
            <div class="col-md-6">
                <a href="/GroundFloor" class="text-decoration-none text-dark">
                    <div class="card shadow-sm border-0">
                        <img src="/img/_DSC5664.jpg" class="card-img-top" style="height: 300px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">Ground Floor</h5>
                            <p class="card-text">
                                Discover the Ground Floor.
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>
<section class="py-5 bg-light text-center">
    <div class="container">

        <div class="row justify-content-center">
            <div class="col-md-6">
                <a href="/SecondFloor" class="text-decoration-none text-dark">
                    <div class="card shadow-sm border-0">
                        <img src="/img/_DSC5475.jpg" class="card-img-top" style="height: 300px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">Second Floor</h5>
                            <p class="card-text">
                                Discover the Second Floor.
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>
<section class="py-5 bg-light text-center">
    <div class="container">

        <div class="row justify-content-center">
            <div class="col-md-6">
                <a href="/ThirdFloor" class="text-decoration-none text-dark">
                    <div class="card shadow-sm border-0">
                        <img src="/img/_DSC5476.jpg" class="card-img-top" style="height: 300px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">Third Floor</h5>
                            <p class="card-text">
                                Discover the Third Floor.
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>





<style>
    .card {
        transition: 0.3s;
    }

        .card:hover {
            transform: scale(1.02);
        }
</style>